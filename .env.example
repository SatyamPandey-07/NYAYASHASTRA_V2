# NYAYASHASTRA Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# BACKEND CONFIGURATION
# ============================================

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# Database Configuration
# SQLite (Development)
DATABASE_URL=sqlite:///./nyayguru.db
# PostgreSQL (Production) - Uncomment and configure
# DATABASE_URL=postgresql://user:password@localhost:5432/nyayashastra

DATABASE_ECHO=false

# Vector Database Configuration
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ============================================
# AI/LLM CONFIGURATION (Choose one or more)
# ============================================

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Groq Configuration (Fast & Free)
GROQ_API_KEY=gsk-your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Local LLM Configuration (Ollama)
USE_LOCAL_LLM=false
LOCAL_LLM_ENDPOINT=http://localhost:11434/api

# ============================================
# REDIS CACHE (Optional)
# ============================================
REDIS_URL=redis://localhost:6379/0
USE_CACHE=false

# ============================================
# SECURITY
# ============================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-minimum-32-characters-required
ALGORITHM=HS256

# ============================================
# DOCUMENT PROCESSING
# ============================================
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,doc,docx

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Backend API URL
VITE_API_URL=http://localhost:8000

# App Configuration
VITE_APP_NAME=NYAYASHASTRA
VITE_APP_VERSION=1.0.0

# Clerk Authentication
# Get your key from: https://dashboard.clerk.com/
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-key-here

# ============================================
# DEPLOYMENT NOTES
# ============================================
# 
# For Production:
# 1. Set API_DEBUG=false
# 2. Use PostgreSQL instead of SQLite
# 3. Set strong SECRET_KEY (min 32 chars)
# 4. Update CORS_ORIGINS with your domain
# 5. Enable Redis caching
# 6. Use production Clerk keys
# 7. Set VITE_API_URL to your backend URL
